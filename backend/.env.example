# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# For local dev with SQLite:
DATABASE_URL="file:./dev.db"

# For PostgreSQL (production):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_NAME=taskflow

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token secret (short-lived, 15 min)
JWT_SECRET=your_jwt_access_secret_change_in_production

# Refresh token secret (long-lived, 7 days)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins or * for all
CORS_ORIGIN=http://localhost:5173
